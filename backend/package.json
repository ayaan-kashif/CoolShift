{
  "name": "coolshift-backend",
  "version": "1.0.0",
  "description": "CoolShift Intelligent Cooling Optimization Platform - Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "ts-node src/seed/generate-data.ts",
    "test": "jest --config jest.config.js",
    "test:acceptance": "jest --config jest.config.js --testPathPattern=acceptance"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "better-sqlite3": "^11.3.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^10.0.0",
    "xlsx": "^0.18.5",
    "json2csv": "^6.0.0-alpha.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/uuid": "^10.0.0",
    "@types/node": "^22.5.0",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "@types/jest": "^29.5.12"
  }
}
